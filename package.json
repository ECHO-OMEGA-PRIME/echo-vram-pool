{
  "name": "echo-vram-pool",
  "version": "1.0.0",
  "private": true,
  "description": "ECHO OMEGA PRIME VRAM Pool Manager — GPU memory allocation across the 4-node cluster",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "db:init": "wrangler d1 execute echo-vram-pool --remote --file=./schema.sql",
    "db:init:local": "wrangler d1 execute echo-vram-pool --local --file=./schema.sql",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.99.0"
  }
}
